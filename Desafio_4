using System;

namespace BatalhaPokemonListaManual
{
    public class Celula
    {
        public Pokemon PokemonContido { get; set; }
        public Celula Prox { get; set; }

        public Celula(Pokemon pokemon)
        {
            this.PokemonContido = pokemon;
            this.Prox = null;
        }
    }
        public class ListaLigadaPokemon
    {
        public Celula Inicio { get; set; }
        public Celula Fim { get; set; }

        public ListaLigadaPokemon()
        {
            Inicio = null;
            Fim = null;
        }

        public void InserirNoFim(Pokemon p)
        {
            Celula nova = new Celula(p);
            if (Inicio == null)
            {
                Inicio = nova;
                Fim = nova;
                return;
            }
            Fim.Prox = nova;
            Fim = nova;
        }

        public Pokemon ObterPorIndice(int indice)
        {
            Celula aux = Inicio;
            int contador = 0;

            while (aux != null)
            {
                if (contador == indice)
                {
                    return aux.PokemonContido;
                }
                contador++;
                aux = aux.Prox;
            }
            return null; 
        }
    }

//---------------- classe pokemons e os tipos ----------
    public class Pokemon
    {
        public string Nome { get; set; }
        public string Tipo { get; set; }
        public int Vida { get; set; }
        public int Ataque { get; set; }
        public int Defesa { get; set; }

        public Pokemon(string nome, string tipo, int vida, int ataque, int defesa)
        {
            Nome = nome;
            Tipo = tipo;
            Vida = vida;
            Ataque = ataque;
            Defesa = defesa;
        }

        public virtual void Atacar(Pokemon alvo)
        {
            int dano = this.Ataque - alvo.Defesa;
            if (dano < 1) dano = 1;

            alvo.Vida -= dano;
            if (alvo.Vida < 0) alvo.Vida = 0;

            Console.WriteLine($"{this.Nome} atacou {alvo.Nome} e causou {dano} de dano.");
            Console.WriteLine($"{alvo.Nome} agora está com {alvo.Vida} de vida.\n");
        }
    }

    public class PokemonFogo : Pokemon
    {
        public PokemonFogo(string nome, int vida, int ataque, int defesa) 
            : base(nome, "Fogo", vida, ataque, defesa) { }

        public override void Atacar(Pokemon alvo)
        {
            int dano = (this.Ataque - alvo.Defesa) + 2;
            if (dano < 1) dano = 1;

            alvo.Vida -= dano;
            if (alvo.Vida < 0) alvo.Vida = 0;

            Console.WriteLine($"{this.Nome} atacou {alvo.Nome} e causou {dano} de dano!");
            Console.WriteLine($"{alvo.Nome} agora está com {alvo.Vida} de vida.\n");
        }
    }

    public class PokemonAgua : Pokemon
    {
        public PokemonAgua(string nome, int vida, int ataque, int defesa) 
            : base(nome, "Água", vida, ataque, defesa) { }

        public override void Atacar(Pokemon alvo)
        {
            int dano = this.Ataque - alvo.Defesa;
            if (dano < 1) dano = 1;

            alvo.Vida -= dano;
            if (alvo.Vida < 0) alvo.Vida = 0;

            Console.WriteLine($"{this.Nome} atacou {alvo.Nome} e causou {dano} de dano.");
            this.Vida += 2; 
            Console.WriteLine($"{this.Nome} recuperou 2 de vida! Vida atual: {this.Vida}\n");
        }
    }

    public class PokemonGrama : Pokemon
    {
        public PokemonGrama(string nome, int vida, int ataque, int defesa) 
            : base(nome, "Grama", vida, ataque, defesa) { }

        public override void Atacar(Pokemon alvo)
        {
            int dano = this.Ataque - alvo.Defesa;
            
            Random rand = new Random();
            if (rand.Next(1, 6) == 1)
            {
                dano += 5;
                Console.WriteLine("ATAQUE CRÍTICO!");
            }
            if (dano < 1) dano = 1;

            alvo.Vida -= dano;
            if (alvo.Vida < 0) alvo.Vida = 0;

            Console.WriteLine($"{this.Nome} atacou {alvo.Nome} e causou {dano} de dano.");
            Console.WriteLine($"{alvo.Nome} agora está com {alvo.Vida} de vida.\n");
        }
    }

//--------- classe dos treinadores --------
    public class Treinador
    {
        public string Nome { get; set; }
        public ListaLigadaPokemon MeusPokemons { get; set; }

        public Treinador(string nome)
        {
            Nome = nome;
            MeusPokemons = new ListaLigadaPokemon(); 
        }

        public void AdicionarPokemon(Pokemon p)
        {
            MeusPokemons.InserirNoFim(p);
        }

        public void ListarPokemons()
        {
            Console.WriteLine($"\n--- Pokémons de {Nome} ---");
            Celula aux = MeusPokemons.Inicio;
            int i = 0;

            while (aux != null)
            {
                Console.WriteLine($"[{i}] [{aux.PokemonContido.Tipo}] {aux.PokemonContido.Nome} - HP: {aux.PokemonContido.Vida}");
                i++;
                aux = aux.Prox;
            }
        }
        public Pokemon EscolherPokemon(int indice)
        {
        Pokemon escolhido = MeusPokemons.ObterPorIndice(indice);

        if (escolhido == null)
        {
            Console.WriteLine($"Índice {indice} inválido! Escolhendo o primeiro Pokémon por padrão.");
            return MeusPokemons.Inicio.PokemonContido;
        }

        return escolhido;
        }
    }

//--------Main - batalhaa -----------
    class Program
    {
        static void Main(string[] args)
        {
            Treinador ash = new Treinador("Ash");
            Treinador misty = new Treinador("Misty");

            ash.AdicionarPokemon(new PokemonFogo("Charmander", 45, 12, 5));
            ash.AdicionarPokemon(new PokemonGrama("Bulbasaur", 50, 10, 6));

            misty.AdicionarPokemon(new PokemonAgua("Squirtle", 48, 11, 7));
            misty.AdicionarPokemon(new PokemonFogo("Vulpix", 40, 13, 4));

            ash.ListarPokemons();
            misty.ListarPokemons();

            Console.WriteLine("\n=== COMBATE COM LISTA LIGADA ===\n");
            Pokemon p1 = ash.MeusPokemons.ObterPorIndice(0);   
            Pokemon p2 = misty.MeusPokemons.ObterPorIndice(0); 
            if (p1 != null && p2 != null)
            {
                Console.WriteLine($"{ash.Nome} escolheu {p1.Nome}!");
                Console.WriteLine($"{misty.Nome} escolheu {p2.Nome}!\n");

                while (p1.Vida > 0 && p2.Vida > 0)
                {
                    p1.Atacar(p2);
                    if (p2.Vida <= 0) break;

                    p2.Atacar(p1);
                }

                if (p1.Vida > 0)
                    Console.WriteLine($"{p1.Nome} venceu! {ash.Nome} ganhou!");
                else
                    Console.WriteLine($"{p2.Nome} venceu! {misty.Nome} ganhou!");
            }
        }
    }
}
