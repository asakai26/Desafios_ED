using System;

namespace ArvoreBinariaBusca
{
        public class Node 
    {
        public int Key { get; set; }
        public Node Left { get; set; }
        public Node Right { get; set; }

        public Node(int key) 
        {
            this.Key = key;
        }
    }
    public class BST 
    {
        public Node Root { get; private set; }

        public BST()
        {
            Root = null;
        }
        public void Insert(int value)
        {
            Root = InsertRecursivo(Root, value);
        }

        private Node InsertRecursivo(Node atual, int value)
        {
            if (atual == null)
            {
                return new Node(value);
            }
            if (value < atual.Key)
            {
                atual.Left = InsertRecursivo(atual.Left, value);
            }
            else if (value > atual.Key)
            {
                atual.Right = InsertRecursivo(atual.Right, value);
            }
            return atual;
        }
                public Node Search(int value)
        {
            return SearchRecursivo(Root, value);
        }

        private Node SearchRecursivo(Node atual, int value)
        {
            if (atual == null || atual.Key == value)
            {
                return atual;
            }
            if (value < atual.Key)
            {
                return SearchRecursivo(atual.Left, value);
            }

            return SearchRecursivo(atual.Right, value);
        }
    }
}
