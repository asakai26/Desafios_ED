using System;

namespace ArvoreBinariaBusca2
{
    public class Node 
    {
        public int Key { get; set; }
        public Node Left { get; set; }
        public Node Right { get; set; }
        
        public Node(int key) 
        {
            this.Key = key;
        }
    }

    public class BST 
    {
        public Node Root { get; private set; }

        public BST()
        {
            Root = null;
        }
        public void Insert(int value)
        {
            Root = InsertRecursivo(Root, value);
        }

        private Node InsertRecursivo(Node atual, int value)
        {
            if (atual == null) return new Node(value);

            if (value < atual.Key)
                atual.Left = InsertRecursivo(atual.Left, value);
            else if (value > atual.Key)
                atual.Right = InsertRecursivo(atual.Right, value);

            return atual;
        }
        public Node MinimoIterativo()
        {
            if (Root == null) return null;

            Node atual = Root;
            while (atual.Left != null)
            {
                atual = atual.Left;
            }
            return atual;
        }
        public Node MinimoRecursivo()
        {
            return MinimoRecursivoAux(Root);
        }

        private Node MinimoRecursivoAux(Node atual)
        {
            if (atual == null) return null;
            if (atual.Left == null) return atual;
            return MinimoRecursivoAux(atual.Left);
        }


        public Node MaximoIterativo()
        {
            if (Root == null) return null;

            Node atual = Root;
            while (atual.Right != null)
            {
                atual = atual.Right;
            }
            return atual;
        }

        public Node MaximoRecursivo()
        {
            return MaximoRecursivoAux(Root);
        }

        private Node MaximoRecursivoAux(Node atual)
        {
            if (atual == null) return null;
            if (atual.Right == null) return atual;

            return MaximoRecursivoAux(atual.Right);
        }
        private void PrintInOrderRecursivoAux(Node atual)
        {
            if (atual != null)
            {
                PrintInOrderRecursivoAux(atual.Left);
                Console.Write($"{atual.Key} ");
                PrintInOrderRecursivoAux(atual.Right);
            }
        }
        public void PrintInOrder()
        {
            PrintInOrderRecursivoAux(Root);
            Console.WriteLine();
        }
        
        public void CoolPrint()
        {
            CoolPrintAux(Root, 0);
        }
        private void CoolPrintAux(Node atual, int nivel)
        {
            if (atual == null) return;
            string recuo = new string(' ', nivel * 4);
            Console.WriteLine($"{recuo}{atual.Key}");
            CoolPrintAux(atual.Left, nivel + 1);
            CoolPrintAux(atual.Right, nivel + 1);
        }
    }

    public class Program 
    {
        public static void Main(string[] args) 
        {
            BST bst = new BST();
            bst.Insert(15);
            bst.Insert(10);
            bst.Insert(8);
            bst.Insert(12);
            bst.Insert(20);
            bst.Insert(21);
            
            Console.WriteLine("EM ORDEM:");
            bst.PrintInOrder();

            Console.WriteLine("\n MÍNIMOS E MÁXIMOS");
            Console.WriteLine($"Mínimo (Iterativo): {bst.MinimoIterativo()?.Key}");
            Console.WriteLine($"Mínimo (Recursivo): {bst.MinimoRecursivo()?.Key}");
            Console.WriteLine($"Máximo (Iterativo): {bst.MaximoIterativo()?.Key}");
            Console.WriteLine($"Máximo (Recursivo): {bst.MaximoRecursivo()?.Key}");

            Console.WriteLine("\n");
            bst.CoolPrint();
        }
    }
}
