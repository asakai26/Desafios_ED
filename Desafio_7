using System;
using System.Collections.Generic;
using System.Diagnostics;

namespace SimuladorArvores
{    public class Node
    {
        public int Key { get; set; }
        public Node Left { get; set; }
        public Node Right { get; set; }
        public int Height { get; set; }

        public Node(int key)
        {
            Key = key;
            Left = null;
            Right = null;
            Height = 1; 
        }
    }
    public class BST
    {
        public Node Root { get; private set; }

        public void Insert(int value)
        {
            Root = InsertRecursivo(Root, value);
        }

        private Node InsertRecursivo(Node atual, int value)
        {
            if (atual == null) return new Node(value);

            if (value < atual.Key)
                atual.Left = InsertRecursivo(atual.Left, value);
            else if (value > atual.Key)
                atual.Right = InsertRecursivo(atual.Right, value);

            return atual;
        }

        public int GetHeight()
        {
            return CalculateHeight(Root);
        }

        private int CalculateHeight(Node node)
        {
            if (node == null) return 0;
            return 1 + Math.Max(CalculateHeight(node.Left), CalculateHeight(node.Right));
        }
    }
    public class AVL
    {
        public Node Root { get; private set; }

        private int Height(Node n) => n == null ? 0 : n.Height;

        private int GetBalance(Node n) => n == null ? 0 : Height(n.Left) - Height(n.Right);
        private Node RotateRight(Node y)
        {
            Node x = y.Left;
            Node T2 = x.Right;

            x.Right = y;
            y.Left = T2;

            y.Height = Math.Max(Height(y.Left), Height(y.Right)) + 1;
            x.Height = Math.Max(Height(x.Left), Height(x.Right)) + 1;

            return x;
        }
        private Node RotateLeft(Node x)
        {
            Node y = x.Right;
            Node T2 = y.Left;

            y.Left = x;
            x.Right = T2;

            x.Height = Math.Max(Height(x.Left), Height(x.Right)) + 1;
            y.Height = Math.Max(Height(y.Left), Height(y.Right)) + 1;

            return y;
        }

        public void Insert(int value)
        {
            Root = InsertRecursivo(Root, value);
        }

        private Node InsertRecursivo(Node node, int value)
        {
            if (node == null) return new Node(value);

            if (value < node.Key)
                node.Left = InsertRecursivo(node.Left, value);
            else if (value > node.Key)
                node.Right = InsertRecursivo(node.Right, value);
            else
                return node;

            node.Height = 1 + Math.Max(Height(node.Left), Height(node.Right));

            int balance = GetBalance(node);

            if (balance > 1 && value < node.Left.Key)
                return RotateRight(node);

            if (balance < -1 && value > node.Right.Key)
                return RotateLeft(node);

            if (balance > 1 && value > node.Left.Key)
            {
                node.Left = RotateLeft(node.Left);
                return RotateRight(node);
            }

            if (balance < -1 && value < node.Right.Key)
            {
                node.Right = RotateRight(node.Right);
                return RotateLeft(node);
            }

            return node;
        }

        public int GetHeight()
        {
            return Height(Root);
        }
    }

    class Program
    {
        static void Main(string[] args)
        {
            string opcao = "";

            while (opcao != "2")
            {
                Console.WriteLine("EP2 - Exemplo de interação");
                Console.WriteLine("-------------------------------------------");
                Console.Write("Menu: 1) nova simulação ou 2) sair\n> _");
                opcao = Console.ReadLine();

                if (opcao == "1")
                {
                    Console.Write("Digite a quantidade de amostras: ");
                    int A = int.Parse(Console.ReadLine());

                    Console.Write("Digite a quantidade de elementos para cada amostra: ");
                    int N = int.Parse(Console.ReadLine());

                    ExecutarSimulacao(A, N);
                }
                else if (opcao == "2")
                {
                    Console.WriteLine("Tchau!");
                }
                else
                {
                    Console.WriteLine("Opção inválida. Tente novamente.\n");
                }
            }
        }

        static void ExecutarSimulacao(int amostras, int elementos)
        {
            Random rand = new Random();
            
            double somaAlturasBST = 0;
            double somaAlturasAVL = 0;
            
            double somaTempoBST = 0;
            double somaTempoAVL = 0;

            for (int a = 0; a < amostras; a++)
            {
                HashSet<int> numerosAleatorios = new HashSet<int>();
                while (numerosAleatorios.Count < elementos)
                {
                    numerosAleatorios.Add(rand.Next(1, 100000));
                }

                BST bst = new BST();
                AVL avl = new AVL();
                Stopwatch swBST = Stopwatch.StartNew();
                foreach (int num in numerosAleatorios)
                {
                    bst.Insert(num);
                }
                swBST.Stop();
                somaAlturasBST += bst.GetHeight();
                somaTempoBST += swBST.Elapsed.TotalSeconds;
                Stopwatch swAVL = Stopwatch.StartNew();
                foreach (int num in numerosAleatorios)
                {
                    avl.Insert(num);
                }
                swAVL.Stop();
                somaAlturasAVL += avl.GetHeight();
                somaTempoAVL += swAVL.Elapsed.TotalSeconds;
            }

            double mediaBST = somaAlturasBST / amostras;
            double mediaAVL = somaAlturasAVL / amostras;
            double mediaGeralAltura = (mediaBST + mediaAVL) / 2;

            double tempoMedioBST = somaTempoBST / amostras;
            double tempoMedioAVL = somaTempoAVL / amostras;
            double tempoMedioGeral = (tempoMedioBST + tempoMedioAVL) / 2;

            Console.WriteLine($"TESTE A = {amostras} e N = {elementos}");
            Console.WriteLine("\n");
            Console.WriteLine($"ALTURA MÉDIA: {mediaGeralAltura:F1}");
            Console.WriteLine($"TEMPO MÉDIO: {tempoMedioGeral} segundos");
            Console.WriteLine($"ALTURA MÉDIA BST: {mediaBST:F1}");
            Console.WriteLine($"TEMPO MÉDIO BST: {tempoMedioBST} segundos");
            Console.WriteLine("\n");
            Console.WriteLine($"ALTURA MÉDIA AVL: {mediaAVL:F1}");
            Console.WriteLine($"TEMPO MÉDIO AVL: {tempoMedioAVL} segundos");
            Console.WriteLine("\n");
        }
    }
}
